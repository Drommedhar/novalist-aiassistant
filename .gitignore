## .gitignore for .NET projects

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet Packages
*.nupkg
*.snupkg

# Others
~$*
*~

# MSBuild Binary and Structured Log
*.binlog

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Visual Studio
.vs/
